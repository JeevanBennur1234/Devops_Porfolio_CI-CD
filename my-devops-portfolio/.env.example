# React Environment Variables
# The URL endpoint for your contact form submission (e.g. Formspree or EmailJS endpoint)
VITE_FORMSPREE_ENDPOINT=https://formspree.io/f/your_form_id

# Other configuration variables needed for your frontend can be added here
# Make sure any variable that should be exposed to the React app starts with VITE_
# VITE_APP_TITLE=My Portfolio
